# Copy this file to .env and fill in values for your environment
# cp .env.example .env

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=inventory_hold_db

# Redis
REDIS_URI=redis://redis:6379

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# Hold settings
HOLD_EXPIRATION_MINUTES=15
POLLING_INTERVAL_SECONDS=30
